      "description": "Anatomical volume processing (bias correction, segmentation, registration). Outputs in 'anat' directory.",
      "outputs": {
        "sub-{SUBJECT}/ses-{SESSION}/anat/sub-{SUBJECT}_ses-{SESSION}*_T1w.nii.gz": [
          "sub-{SUBJECT}/ses-{SESSION}/anat/sub-{SUBJECT}_ses-{SESSION}*_desc-preproc_T1w.nii.gz",
          "sub-{SUBJECT}/ses-{SESSION}/anat/sub-{SUBJECT}_ses-{SESSION}*_from-T1w_to-MNI152NLin6Asym_mode-image_xfm.h5",
          "sub-{SUBJECT}/ses-{SESSION}/anat/sub-{SUBJECT}_ses-{SESSION}*_from-MNI152NLin6Asym_to-T1w_mode-image_xfm.h5",          
          "sub-{SUBJECT}/ses-{SESSION}/anat/sub-{SUBJECT}_ses-{SESSION}*_desc-brain_mask.nii.gz",
          "sub-{SUBJECT}/ses-{SESSION}/anat/sub-{SUBJECT}_ses-{SESSION}*_space-MNI152NLin6Asym_res-2_desc-brain_mask.nii.gz",
          "sub-{SUBJECT}/ses-{SESSION}/anat/sub-{SUBJECT}_ses-{SESSION}*_label-CSF_probseg.nii.gz",
          "sub-{SUBJECT}/ses-{SESSION}/anat/sub-{SUBJECT}_ses-{SESSION}*_label-GM_probseg.nii.gz",
          "sub-{SUBJECT}/ses-{SESSION}/anat/sub-{SUBJECT}_ses-{SESSION}*_label-WM_probseg.nii.gz"
