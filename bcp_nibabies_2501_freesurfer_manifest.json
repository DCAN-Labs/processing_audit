          "sub-{SUBJECT}/ses-{SESSION}/anat/sub-{SUBJECT}_ses-{SESSION}*_space-fsLR_den-32k_hemi-R_white.surf.gii",
          "sub-{SUBJECT}/ses-{SESSION}/anat/sub-{SUBJECT}_ses-{SESSION}*_space-T1w_desc-brain_mask.nii.gz",
          "sub-{SUBJECT}/ses-{SESSION}/anat/sub-{SUBJECT}_ses-{SESSION}*_hemi-L_curv.dscalar.nii",
          "sub-{SUBJECT}/ses-{SESSION}/anat/sub-{SUBJECT}_ses-{SESSION}*_hemi-R_curv.dscalar.nii",
          "sub-{SUBJECT}/ses-{SESSION}/anat/sub-{SUBJECT}_ses-{SESSION}*_hemi-L_sulc.dscalar.nii",
          "sub-{SUBJECT}/ses-{SESSION}/anat/sub-{SUBJECT}_ses-{SESSION}*_hemi-R_sulc.dscalar.nii",
          "sub-{SUBJECT}/ses-{SESSION}/anat/sub-{SUBJECT}_ses-{SESSION}*_hemi-L_thickness.dscalar.nii",
          "sub-{SUBJECT}/ses-{SESSION}/anat/sub-{SUBJECT}_ses-{SESSION}*_hemi-R_thickness.dscalar.nii",
          "sub-{SUBJECT}/ses-{SESSION}/anat/sub-{SUBJECT}_ses-{SESSION}*_hemi-L_space-fsLR_den-91k_curv.dscalar.nii",
          "sub-{SUBJECT}/ses-{SESSION}/anat/sub-{SUBJECT}_ses-{SESSION}*_hemi-R_space-fsLR_den-91k_curv.dscalar.nii",
