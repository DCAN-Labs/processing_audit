          "sub-{SUBJECT}/ses-{SESSION}/func/sub-{SUBJECT}_ses-{SESSION}_task-rest_*run-*4*_space-MNI152NLin6Asym_res-2_desc-preproc_bold.nii.gz",          
          "sub-{SUBJECT}/ses-{SESSION}/func/sub-{SUBJECT}_ses-{SESSION}_task-rest_*run-*4*_space-MNI152NLin6Asym_res-2_boldref.nii.gz",
          "sub-{SUBJECT}/ses-{SESSION}/func/sub-{SUBJECT}_ses-{SESSION}_task-rest_*run-*4*_space-MNI152NLin6Asym_res-2_desc-brain_mask.nii.gz",
          "sub-{SUBJECT}/ses-{SESSION}/func/sub-{SUBJECT}_ses-{SESSION}_task-rest_*run-*4*_desc-confounds_timeseries.tsv"
        ],
        "sub-{SUBJECT}/ses-{SESSION}/func/sub-{SUBJECT}_ses-{SESSION}_task-rest_*run-*5*_bold.nii.gz": [
          "sub-{SUBJECT}/ses-{SESSION}/func/sub-{SUBJECT}_ses-{SESSION}_task-rest_*run-*5*_desc-hmc_boldref.nii.gz",
          "sub-{SUBJECT}/ses-{SESSION}/func/sub-{SUBJECT}_ses-{SESSION}_task-rest_*run-*5*_desc-coreg_boldref.nii.gz",
          "sub-{SUBJECT}/ses-{SESSION}/func/sub-{SUBJECT}_ses-{SESSION}_task-rest_*run-*5*_from-boldref*.txt",
          "sub-{SUBJECT}/ses-{SESSION}/func/sub-{SUBJECT}_ses-{SESSION}_task-rest_*run-*5*_space-MNI152NLin6Asym_res-2_desc-preproc_bold.nii.gz",          
