          "sub-{SUBJECT}/ses-{SESSION}/func/sub-{SUBJECT}_ses-{SESSION}_task-rest_*run-*2*_from-boldref*.txt",
          "sub-{SUBJECT}/ses-{SESSION}/func/sub-{SUBJECT}_ses-{SESSION}_task-rest_*run-*2*_space-MNI152NLin6Asym_res-2_desc-preproc_bold.nii.gz",          
