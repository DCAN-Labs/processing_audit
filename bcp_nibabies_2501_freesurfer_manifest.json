          "sub-{SUBJECT}/ses-{SESSION}/func/sub-{SUBJECT}_ses-{SESSION}_task-rest_*run-*6*_desc-coreg_boldref.nii.gz",
          "sub-{SUBJECT}/ses-{SESSION}/func/sub-{SUBJECT}_ses-{SESSION}_task-rest_*run-*6*_from-boldref*.txt",
