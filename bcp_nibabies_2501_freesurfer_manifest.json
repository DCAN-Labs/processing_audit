{
  "pipeline": "nibabies",
  "version": "25.0.1",
  "parameters": {
    "cifti-output": "91k",
    "output-spaces": "MNI152NLin6Asym:res-2",
    "surface-recon-method": "freesurfer"
  },
  "manifest": {
