          "sub-{SUBJECT}/ses-{SESSION}/anat/sub-{SUBJECT}_ses-{SESSION}*_from-T1w_to_T2w_mode-image_xfm.h5"

        ]
      }
    },
    "FreeSurfer": {
      "description": "Infant FreeSurfer surface reconstruction outputs",
      "outputs": {
        "sub-{SUBJECT}/ses-{SESSION}/anat/sub-{SUBJECT}_ses-{SESSION}*_T1w.nii.gz": [
          "sourcedata/sub-{SUBJECT}_ses-{SESSION}/surf/lh.white",
          "sourcedata/sub-{SUBJECT}_ses-{SESSION}/surf/rh.white",
