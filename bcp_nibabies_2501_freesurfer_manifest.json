          "sub-{SUBJECT}/ses-{SESSION}/anat/sub-{SUBJECT}_ses-{SESSION}*_hemi-L_midthickness.surf.gii",
          "sub-{SUBJECT}/ses-{SESSION}/anat/sub-{SUBJECT}_ses-{SESSION}*_hemi-R_midthickness.surf.gii",
          "sub-{SUBJECT}/ses-{SESSION}/anat/sub-{SUBJECT}_ses-{SESSION}*_space-fsLR_den-32k_hemi-L_pial.surf.gii",
